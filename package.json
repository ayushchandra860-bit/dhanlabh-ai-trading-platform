{
  "main": "dist-electron/electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "start:electron": "electron .",
    "clean": "node -e \"const fs=require('fs'); ['dist','dist-electron','node_modules/.vite','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "build:frontend": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run clean && npm run build:frontend && npm run build:electron",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.dhanlabh.ai",
    "productName": "DhanLabh AI V2",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}