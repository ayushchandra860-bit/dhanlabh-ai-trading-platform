# Server
NODE_ENV=production
PORT=10000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret

# Optional Supabase PostgreSQL persistence.
# The app works with an in-memory fallback when these are absent.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional free-market-data fallback.
# TwelveData free tier can improve Forex coverage when configured.
TWELVEDATA_API_KEY=
